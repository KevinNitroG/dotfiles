{
  "mcpServers": {
    "context7": {
      "command": "mise",
      "args": [
        "exec",
        "npm:@upstash/context7-mcp@latest",
        "--",
        "context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "trust": true
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      },
      "trust": true
    }
  }
}
