encryption = "gpg"
mode = "file" # file, symlink
progress = true

[git]
autoAdd = true # Add changes to the source state after any change
autoCommit = false
autoPush = false

[gpg]
recipient = "KevinNitroG"

[cd]
{{ $shell := "" }}
{{- if eq .chezmoi.os "windows" -}}
{{-  $shell = "pwsh" -}}
{{- else -}}
{{-   $shell = "zsh" -}}
{{- end -}}
command = {{ $shell | quote }}

[completion]
custom = true

[edit]
command = "nvim"

[diff]
command = "delta"
pager = "delta"

[merge]
command = "nvim"
args = ["-d", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}", "{{ "{{" }} .Target {{ "}}" }}"]

