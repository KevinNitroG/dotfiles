format = "[ $symbol]($style)"

[cmd_duration]
disabled = false
min_time = 2_000
show_milliseconds = false
show_notifications = false
min_time_to_notify = 300_000
format = '[ ´É║  $duration ](fg:surface0 bg:lavender)'

[line_break]
disabled = false

[character]
disabled = false
success_symbol = '[´É▓](bold fg:text)'
error_symbol = '[´É▓](bold fg:red)'
vimcmd_symbol = '[´É┤](bold fg:text)'
vimcmd_replace_one_symbol = '[´É┤](bold fg:blue)'
vimcmd_replace_symbol = '[´É┤](bold fg:lavender)'
vimcmd_visual_symbol = '[´É┤](bold fg:yellow)'
