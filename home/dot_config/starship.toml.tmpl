[username]
show_always = true
style_user = "bg:surface0 fg:text"
style_root = "bold bg:surface0 fg:maroon"
format = '[ $user ]($style)'

[hostname]
ssh_only = false
style = "bg:red fg:base"
format = "[ ($ssh_symbol )$hostname ]($style)"

[directory]
style = "fg:base bg:peach"
format = "[ $path ]($style)"
truncation_symbol = "ÔÇª/"

[directory.substitutions]
"Documents" = "¾░êÖ "
"Downloads" = "´ÇÖ "
"Music" = "¾░ØÜ "
"Pictures" = "´Ç¥ "
"code" = "´äí "
"projects" = "¯¼░ "
"homelab" = "¾▒â¥ "
"nvim" = "¯á║ "
".vim" = "¯ƒà "
"chezmoi" = "¾░ÿô "

[git_branch]
symbol = "´Éÿ"
style = "bg:yellow"
format = '[[ $symbol $branch ](fg:base bg:yellow)]($style)'

[git_status]
style = "bg:yellow"
format = '[[($all_status$ahead_behind )](fg:base bg:yellow)]($style)'
ahead = "Ôçí${count}"
behind = "Ôçú${count}"
diverged = "ÔçòÔçí${ahead_count}Ôçú${behind_count}"
untracked = "?${count}"
modified = "!${count}"
staged = "+${count}"
renamed = "┬╗${count}"
deleted = "Ô£ÿ${count}"

[nodejs]
symbol = "¯£ÿ"
style = "bg:text"
format = '[[ $symbol( $version) ](fg:base bg:green)]($style)'

[c]
symbol = "¯ÿ× "
style = "bg:text"
format = '[[ $symbol( $version) ](fg:base bg:green)]($style)'

[rust]
symbol = "¯×¿"
style = "bg:text"
format = '[[ $symbol( $version) ](fg:base bg:green)]($style)'

[golang]
symbol = "¯ÿº"
style = "bg:text"
format = '[[ $symbol( $version)( $mod_version) ](fg:base bg:green)]($style)'

[php]
symbol = "¯ÿê"
style = "bg:text"
format = '[[ $symbol( $version) ](fg:base bg:green)]($style)'

[gradle]
symbol = "¯ƒ▓"
style = "bg:text"
format = '[[ $symbol( $version) ](fg:base bg:green)]($style)'

[java]
symbol = "¯ëû "
style = "bg:text"
format = '[[ $symbol( $version) ](fg:base bg:green)]($style)'

[kotlin]
symbol = "¯ÿ┤"
style = "bg:text"
