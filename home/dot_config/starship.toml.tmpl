[docker_context]
symbol = "´îê"
style = "bg:blue"
format = '[[ $symbol( $context) ](fg:base bg:blue)]($style)'

[kubernetes]
style = "bg:blue"
format = '[[ $symbol( $context)( \($namespace\)) ](fg:base bg:blue)]($style)'
disabled = false
symbol ="¾▒â¥"

[terraform]
style = "bg:blue"
format = '[[ $symbol( $version)( \($workspace\)) ](fg:base bg:blue)]($style)'
symbol = "¯ó¢"

[conda]
style = "bg:blue"
format = '[[ $symbol( $environment) ](fg:#base bg:blue)]($style)'

[time]
disabled = true
time_format = "%R"
style = "bg:color_bg1"
format = '[[ ´É║ $time ](fg:base bg:lavender)]($style)'

[sudo]
style = "fg:base bg:lavender"
