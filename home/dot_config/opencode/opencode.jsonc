{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-haiku-4.5",
  "small_model": "github-copilot/gpt-4.1",
  "autoupdate": false,
  "agent": {
    "compaction": {
      "model": "google/gemini-2.5-flash",
      "options": {
        "thinkingBudget": 0,
        "includeThoughts": false,
      },
    },
    "build": {
      "model": "google/antigravity-claude-sonnet-4-6",
    },
    "plan": {
      "model": "google/antigravity-gemini-3.1-pro",
    },
    "general": {
      "disable": true,
      "model": "google/gemini-2.5-pro",
    },
    "explore": {
      "disable": true,
      "model": "google/gemini-2.5-pro",
    },
  },
  "plugin": [
    "opencode-wakatime@latest",
    "opencode-antigravity-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "kdco/background-agents@latest",
    "opencode-pty@latest",
    "oh-my-opencode-slim@latest",
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:chrome-devtools-mcp@latest",
        "--",
        "chrome-devtools-mcp",
      ],
      "enabled": false,
    },
    "context7": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@upstash/context7-mcp@latest",
        "--",
        "context7-mcp",
      ],
      "enabled": false,
    },
    "ddg-search": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "pipx:duckduckgo-mcp-server@latest",
        "--",
        "duckduckgo-mcp-server",
      ],
      "enabled": false,
    },
    "brave-search": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@brave/brave-search-mcp-server@latest",
        "--",
        "brave-search-mcp-server",
      ],
      "environment": {
        "BRAVE_SEARCH_API_KEY": "{env:BRAVE_SEARCH_API_KEY}",
      },
      "enabled": false,
    },
    "fetch": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:mcp-fetch-server@latest",
        "--",
        "mcp-fetch-server",
      ],
      "enabled": false,
    },
    "filesystem": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-filesystem@latest",
        "--",
        "mcp-server-filesystem",
        "~/",
      ],
      "enabled": false,
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}",
      },
    },
    "google-sheets": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "pipx:mcp-google-sheets@latest",
        "--",
        "mcp-google-sheets",
      ],
      "enabled": false,
      "environment": {
        "CREDENTIALS_PATH": "${HOME}/.config/mcp/mcp-google-sheet/credentials.json",
        "TOKEN_PATH": "${HOME}/.config/mcp/mcp-google-sheet/token.json",
      },
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:mcp-server-kubernetes@latest",
        "--",
        "mcp-server-kubernetes",
      ],
      "enabled": false,
    },
    "memory": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-memory@latest",
        "--",
        "server-memory",
      ],
      "enabled": false,
    },
    "playwright": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@playwright/mcp@latest",
        "--",
        "playwright-mcp",
        "--config",
        "/home/kevinnitro/.config/playwright-mcp.json",
      ],
      "enabled": false,
      "environment": {
        "WAYLAND_DISPLAY": "{env:WAYLAND_DISPLAY}",
        "XDG_RUNTIME_DIR": "{env:XDG_RUNTIME_DIR}",
      },
    },
    "puppeteer": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-puppeteer@latest",
        "--",
        "server-puppeteer",
      ],
      "enabled": false,
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-sequential-thinking@latest",
        "--",
        "server-sequential-thinking",
      ],
      "enabled": false,
    },
    "tavily": {
      "type": "local",
      "command": ["mise", "exec", "npm:tavily-mcp@latest", "--", "tavily-mcp"],
      "enabled": false,
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}",
      },
    },
    "time": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "pipx:mcp-server-time@latest",
        "--",
        "mcp-server-time",
        "--local-timezone=Asia/Ho_Chi_Minh",
      ],
      "enabled": false,
    },
    "Framelink_Figma_MCP": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:figma-developer-mcp@latest",
        "--",
        "figma-developer-mcp",
        "--stdio",
      ],
      "enabled": false,
      "environment": {
        "FIGMA_API_KEY": "{env:FIGMA_API_KEY}",
      },
    },
    "shadcn": {
      "type": "local",
      "command": ["mise", "exec", "npm:shadcn@latest", "--", "shadcn", "mcp"],
      "enabled": false,
    },
  },
  "provider": {
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": {
              "thinkingLevel": "low",
            },
            "high": {
              "thinkingLevel": "high",
            },
          },
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": {
              "thinkingLevel": "low",
            },
            "high": {
              "thinkingLevel": "high",
            },
          },
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "minimal": {
              "thinkingLevel": "minimal",
            },
            "low": {
              "thinkingLevel": "low",
            },
            "medium": {
              "thinkingLevel": "medium",
            },
            "high": {
              "thinkingLevel": "high",
            },
          },
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192,
              },
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768,
              },
            },
          },
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
      },
    },
  },
}
