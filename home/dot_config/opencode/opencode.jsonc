{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/gpt-4.1",
  "autoupdate": false,
  "agent": {
    "compaction": {
      "model": "google/gemini-2.5-flash",
      "options": {
        "thinkingBudget": 0,
        "includeThoughts": false
      }
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "plan": {
      "model": "github-copilot/gemini-3.1-pro-preview"
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:chrome-devtools-mcp@latest",
        "--",
        "chrome-devtools-mcp"
      ],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@upstash/context7-mcp@latest",
        "--",
        "context7-mcp"
      ],
      "enabled": false
    },
    "ddg-search": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "pipx:duckduckgo-mcp-server@latest",
        "--",
        "duckduckgo-mcp-server"
      ],
      "enabled": false
    },
    "brave-search": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@brave/brave-search-mcp-server@latest",
        "--",
        "brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_SEARCH_API_KEY": "{env:BRAVE_SEARCH_API_KEY}"
      },
      "enabled": false
    },
    "fetch": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:mcp-fetch-server@latest",
        "--",
        "mcp-fetch-server"
      ],
      "enabled": false
    },
    "filesystem": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-filesystem@latest",
        "--",
        "mcp-server-filesystem",
        "~/"
      ],
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "google-sheets": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "pipx:mcp-google-sheets@latest",
        "--",
        "mcp-google-sheets"
      ],
      "enabled": false,
      "environment": {
        "CREDENTIALS_PATH": "${HOME}/.config/mcp/mcp-google-sheet/credentials.json",
        "TOKEN_PATH": "${HOME}/.config/mcp/mcp-google-sheet/token.json"
      }
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:mcp-server-kubernetes@latest",
        "--",
        "mcp-server-kubernetes"
      ],
      "enabled": false
    },
    "memory": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-memory@latest",
        "--",
        "server-memory"
      ],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@playwright/mcp@latest",
        "--",
        "playwright-mcp",
        "--config",
        "/home/kevinnitro/.config/playwright-mcp.json"
      ],
      "enabled": false,
      "environment": {
        "WAYLAND_DISPLAY": "{env:WAYLAND_DISPLAY}",
        "XDG_RUNTIME_DIR": "{env:XDG_RUNTIME_DIR}"
      }
    },
    "puppeteer": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-puppeteer@latest",
        "--",
        "server-puppeteer"
      ],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:@modelcontextprotocol/server-sequential-thinking@latest",
        "--",
        "server-sequential-thinking"
      ],
      "enabled": false
    },
    "tavily": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:tavily-mcp@latest",
        "--",
        "tavily-mcp"
      ],
      "enabled": false,
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}"
      }
    },
    "time": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "pipx:mcp-server-time@latest",
        "--",
        "mcp-server-time",
        "--local-timezone=Asia/Ho_Chi_Minh"
      ],
      "enabled": false
    },
    "Framelink_Figma_MCP": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:figma-developer-mcp@latest",
        "--",
        "figma-developer-mcp",
        "--stdio"
      ],
      "enabled": false,
      "environment": {
        "FIGMA_API_KEY": "{env:FIGMA_API_KEY}"
      }
    },
    "shadcn": {
      "type": "local",
      "command": [
        "mise",
        "exec",
        "npm:shadcn@latest",
        "--",
        "shadcn",
        "mcp"
      ],
      "enabled": false
    }
  },
  "plugin": [
    "opencode-wakatime@latest",
    "opencode-gemini-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "kdco/background-agents@latest",
    "opencode-pty@latest",
    "opencode-antigravity-auth@latest",
    "oh-my-opencode-slim"
  ],
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification.",
      "model": "github-copilot/gpt-4.1"
    }
  }
}
