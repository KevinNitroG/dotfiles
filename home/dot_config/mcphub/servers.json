{
  "mcpServers": {
    "sequential-thinking": {
      "disabled": true,
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx"
    },
    "filesystem": {
      "autoApprove": [
        
      ],
      "disabled": true,
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/kevinnitro"
      ],
      "command": "npx"
    },
    "context7": {
      "disabled": true,
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "command": "npx"
    },
    "playwright": {
      "disabled": true,
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "command": "npx"
    },
    "vectorcode": {
      "disabled": true,
      "command": "vectorcode-mcp-server"
    },
    "tavily": {
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "disabled": true,
      "args": [
        "/path/to/tavily-mcp/build/index.js"
      ],
      "command": "npx"
    },
    "github": {
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      },
      "disabled": true,
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "supabase-local": {
      "disabled": true,
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "http://localhost:54323"
      ],
      "command": "npx"
    },
    "puppeteer": {
      "disabled": true,
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "command": "npx"
    },
    "supabase": {
      "autoApprove": [
        
      ],
      "disabled": false,
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "${SUPABASE_TOKEN}"
      ],
      "command": "npx"
    },
    "time": {
      "disabled": false,
      "args": [
        "mcp-server-time",
        "--local-timezone=Asia/Ho_Chi_Minh"
      ],
      "command": "uvx"
    },
    "kubernetes": {
      "disabled": true,
      "args": [
        "mcp-server-kubernetes"
      ],
      "command": "npx"
    },
    "git": {
      "disabled": true,
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/kevinnitro"
      ],
      "command": "uvx"
    },
    "ddg-search": {
      "args": [
        "duckduckgo-mcp-server"
      ],
      "command": "uvx"
    },
    "fetch": {
      "disabled": true,
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    }
  },
  "nativeMCPServers": {
    "neovim": {
      "disabled": false,
      "autoApprove": [
        
      ],
      "disabled_prompts": [
        "parrot"
      ]
    },
    "mcphub": {
      "disabled": true,
      "autoApprove": [
        
      ],
      "disabled_resources": [
        "mcphub://docs",
        "mcphub://native_server_guide",
        "mcphub://changelog"
      ],
      "disabled_tools": [
        
      ],
      "disabled_prompts": [
        "create_native_server"
      ]
    }
  }
}