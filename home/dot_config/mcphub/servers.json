{
  "mcpServers": {
    "supabase-local": {
      "disabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "http://localhost:54323"
      ]
    },
    "git": {
      "disabled": true,
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/kevinnitro"
      ]
    },
    "supabase": {
      "disabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "${SUPABASE_TOKEN}"
      ]
    },
    "fetch": {
      "disabled": false,
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/kevinnitro"
      ]
    },
    "vectorcode": {
      "disabled": true,
      "command": "uvx",
      "args": [
        "--from=vectorcode",
        "--with=vectorcode[mcp]",
        "--index=https://download.pytorch.org/whl/cpu",
        "--index-strategy=unsafe-best-match",
        "vectorcode-mcp-server"
      ]
    },
    "kubernetes": {
      "disabled": true,
      "command": "npx",
      "args": [
        "mcp-server-kubernetes"
      ]
    },
    "puppeteer": {
      "disabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "github": {
      "disabled": false,
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    }
  },
  "nativeMCPServers": {
    "neovim": {
      "disabled": false,
      "disabled_prompts": [
        "parrot"
      ],
      "autoApprove": [
        
      ]
    },
    "mcphub": {
      "disabled": false,
      "disabled_prompts": [
        "create_native_server"
      ],
      "autoApprove": [
        
      ],
      "disabled_resources": [
        "mcphub://docs",
        "mcphub://native_server_guide",
        "mcphub://changelog"
      ],
      "disabled_tools": [
        
      ]
    }
  }
}