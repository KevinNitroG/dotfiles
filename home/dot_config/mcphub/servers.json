{
  "nativeMCPServers": {
    "mcphub": {
      "disabled": false,
      "disabled_resources": [
        "mcphub://docs",
        "mcphub://native_server_guide",
        "mcphub://changelog"
      ],
      "disabled_tools": [
        
      ],
      "autoApprove": [
        
      ],
      "disabled_prompts": [
        "create_native_server"
      ]
    },
    "neovim": {
      "disabled": false,
      "autoApprove": [
        
      ],
      "disabled_prompts": [
        "parrot"
      ]
    }
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/kevinnitro"
      ]
    },
    "fetch": {
      "disabled": false,
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "kubernetes": {
      "disabled": true,
      "command": "npx",
      "args": [
        "mcp-server-kubernetes"
      ]
    },
    "puppeteer": {
      "disabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "git": {
      "disabled": true,
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/kevinnitro"
      ]
    },
    "github": {
      "disabled": false,
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    }
  }
}